{
  "name": "mini-lineage",
  "version": "1.5.0",
  "description": "Mini-Lineage Remastered is a modern rewrite of the original Mini-Lineage game.",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "prebuild": "npm run test",
    "build:css": "ts-node scripts/build-css.ts",
    "build:js": "ts-node scripts/build-js.ts",
    "build": "rm -rf dist && tsc && tsc-alias && mkdir -p dist/view/template && cp -r src/view/template dist/view/ && npm run build:css && npm run build:js && git rev-parse --short HEAD > dist/version.txt",
    "db:fresh": "ts-node -r tsconfig-paths/register scripts/reset-db.ts",
    "db:migrate": "ts-node -r tsconfig-paths/register scripts/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "Sunny",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.3.0",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "mysql2": "^3.17.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/clean-css": "^4.2.11",
    "@types/compression": "^1.8.1",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-mysql-session": "^3.0.8",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.3.0",
    "@types/pino": "^7.0.4",
    "@types/terser": "^3.8.1",
    "clean-css-cli": "^5.6.3",
    "nodemon": "^3.1.14",
    "terser": "^5.46.1",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
