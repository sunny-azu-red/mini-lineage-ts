<h2>Welcome, brave wanderer!</h2>
<p>
    Will you embark on a new journey, or perhaps reflect upon the legends within the <a href="/highscores">Hall of Champions</a>?
    The deeds of all who came before are etched within <a href="/statistics">The Tome of Lore</a>, a chronicle of our shared history.
</p>
<p>Under what name and through which lineage shall your own tale begin?</p>

<form action="/start" method="post">
    <div class="form-row">
        <input type="text" class="form-input" name="name" maxlength="18" placeholder="Identify yourself, champion..." required />
        <select class="form-select" name="select_race">
            <% races.forEach(race => { %>
                <option value="<%= race.id %>"><%= race.emoji %> <%= race.label %></option>
            <% }) %>
        </select>
        <button type="submit" class="btn">🚩 Begin</button>
    </div>
</form>
