<% if (coward) { %>
    <div class="alert alert-danger">
        <%- reason %>
    </div>
<% } else { %>
    <p><%- reason %></p>
<% } %>

<div class="action-links">
    <% if (!coward) { %>
        <form action="/highscores" method="post">
            <button type="submit" class="btn">📜 Write your Legacy!</button>
        </form>
    <% } %>
    <a href="/restart" class="btn btn-secondary">Play Again?</a>
</div>
