<p>
    You have arrived at the Inn.<br>
    The young lady greets you and sets you at a table.
</p>

<div class="table-container">
    <table class="data-table" style="min-width: 400px">
        <thead>
            <tr>
                <th>Name</th>
                <th title="Health Point Recovery">HP Recovery</th>
                <th>Adena</th>
            </tr>
        </thead>
        <tbody>
            <% items.forEach(function(food) { %>
                <tr>
                    <td><%= food.emoji %> <%= food.name %></td>
                    <td><%= food.statFormatted %></td>
                    <td class="gold">🪙 <%= food.costFormatted %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<form action="/inn" method="post">
    <div class="form-row">
        <select class="form-select" name="select_food" id="inn-select">
            <option value="">🚪 Home Town</option>
            <% items.forEach(function(f) { %>
                <option value="<%= f.id %>">Pick <%= f.emoji %> <%= f.name %></option>
            <% }); %>
        </select>
        <button type="submit" class="btn btn-secondary" id="inn-btn">Return</button>
    </div>
</form>
