<p>
    You have arrived at the Weapons Shop.<br>
    The nice man greets you and lets you look through his swords.
</p>

<div class="table-container">
    <table class="data-table" style="min-width: 400px">
        <thead>
            <tr>
                <th>Name</th>
                <th title="Critical Hit Chance">C. Hit %</th>
                <th title="Physical Attack">P. Attack</th>
                <th>Adena</th>
            </tr>
        </thead>
        <tbody>
            <% items.forEach(function(weapon) { %>
                <tr>
                    <td><%= weapon.emoji %> <%= weapon.name %></td>
                    <td><% if (weapon.crit > 0) { %><span class="crit"><%= weapon.crit %>%</span><% } else { %><span class="muted">-</span><% } %></td>
                    <td><%= weapon.statFormatted %></td>
                    <td class="gold">🪙 <%= weapon.costFormatted %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<form action="/shop/weapons" method="post">
    <div class="form-row">
        <select class="form-select" name="select_weapon" id="weapon-select">
            <option value="">🚪 Home Town</option>
            <% items.forEach(function(w) { %>
                <option value="<%= w.id %>" <%= player.weaponId === w.id ? 'disabled' : '' %>>
                    Pick <%= w.emoji %> <%= w.name %> <%= player.weaponId === w.id ? '(Owned)' : '' %>
                </option>
            <% }); %>
        </select>
        <button type="submit" class="btn btn-secondary" id="weapon-btn">Return</button>
    </div>
</form>
