<div class="panel status-panel">
    <div class="panel-header">
        <% if (playerName) { %>
            <span title="Your legend"><%= playerName %></span>
        <% } else { %>
            Status
        <% } %>
    </div>
    <div class="panel-body small">
        <div class="stat-row">
            <span class="stat-label">Race</span>
            <span class="stat-value"><%- levelDisplay %></span>
        </div>
        <div class="stat-row bar <% if (isLowHealth) { %>danger<% } %>">
            <span class="stat-label">HP</span>
            <div class="bar-track">
                <div class="bar hp-bar" id="hp-bar" style="width: <%= prevHpPercent %>%" data-width="<%= hpPercent %>"></div>
                <span class="bar-text">
                    <span class="animate-val" data-val="<%= hp %>" data-prev="<%= prevHp %>"><%= prevHp %></span>/<%= maxHp %>
                </span>
            </div>
        </div>
        <div class="stat-row bar">
            <span class="stat-label">XP</span>
            <div class="bar-track">
                <div class="bar xp-bar" id="xp-bar" style="width: <%= prevXpPercent %>%" data-width="<%= isMaxLevel ? 100 : xpPercent %>"></div>
                <span class="bar-text">
                    <% if (isMaxLevel) { %>
                        <span class="animate-val" data-val="<%= totalXp %>" data-prev="<%= prevTotalXp %>"><%= prevTotalXp %></span>
                    <% } else { %>
                        <span class="animate-val" data-val="<%= currentXp %>" data-prev="<%= prevCurrentXp %>"><%= prevCurrentXp %></span>/<%= nextLevelXp %>
                    <% } %>
                </span>
            </div>
        </div>
        <div class="stat-row">
            <span class="stat-label">Adena</span>
            <span class="stat-value gold">🪙 <span class="animate-val" data-val="<%= adena %>" data-prev="<%= prevAdena %>" data-final="<%= adenaFormatted %>"><%= adenaFormatted %></span></span>
        </div>
    </div>
</div>

