<div class="panel status-panel">
    <div class="panel-header">
        <span><%= playerName %></span>
    </div>
    <div class="panel-body small">
        <div class="stat-row">
            <span class="stat-label">Race</span>
            <span class="stat-value"><%- levelDisplay %></span>
        </div>
        <div class="stat-row bar <% if (isLowHealth) { %>danger<% } %>">
            <span class="stat-label">HP</span>
            <div class="bar-track">
                <div class="bar hp-bar" id="hp-bar" style="width: <%= prevHpPercent %>%" data-width="<%= hpPercent %>"></div>
                <span class="bar-text">
                    <span class="animate-val" data-val="<%= hp %>" data-prev="<%= prevHp %>"><%= prevHpFormatted %></span>/<%= maxHpFormatted %>
                </span>
            </div>
        </div>
        <div class="stat-row bar">
            <span class="stat-label">XP</span>
            <div class="bar-track">
                <div class="bar xp-bar" id="xp-bar" style="width: <%= prevXpPercent %>%" data-width="<%= isMaxLevel ? 100 : xpPercent %>"></div>
                <span class="bar-text">
                    <% if (isMaxLevel) { %>
                        <span class="animate-val" data-val="<%= totalXp %>" data-prev="<%= prevTotalXp %>"><%= prevTotalXpFormatted %></span>
                    <% } else { %>
                        <span class="animate-val" data-val="<%= currentXp %>" data-prev="<%= prevCurrentXp %>"><%= prevCurrentXpFormatted %></span>/<%= nextLevelXpFormatted %>
                    <% } %>
                </span>
            </div>
        </div>
        <div class="stat-row">
            <span class="stat-label">Adena</span>
            <span class="stat-value gold">🪙 <%= adenaFormatted %></span>
        </div>
    </div>
</div>
