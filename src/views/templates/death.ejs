<% if (coward) { %>
    <div class="alert alert-danger">
        <%- reason %>
    </div>
<% } else { %>
    <p><%- reason %></p>
<% } %>

<div class="action-links">
    <% if (!coward) { %>
        <a href="/highscores/submit" class="btn">📜 Write your Legacy!</a>
    <% } %>
    <a href="/restart" class="btn btn-secondary">Play Again?</a>
</div>
